generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  listener
  artist
  admin

  @@map("user_role")
}

enum AlbumType {
  album
  single
  ep
  compilation

  @@map("album_type")
}

enum StorageProvider {
  url
  local
  s3
  gcs
  cloudinary

  @@map("storage_provider")
}

enum PlaylistVisibility {
  private
  public
  unlisted

  @@map("playlist_visibility")
}

enum PlaySource {
  album
  playlist
  search
  radio
  direct

  @@map("play_source")
}

model User {
  id           String          @id @default(uuid()) @db.Uuid
  displayName  String          @map("display_name") @db.VarChar(80)
  email        String          @unique @db.VarChar(255)
  passwordHash String          @map("password_hash")
  avatarUrl    String?         @map("avatar_url")
  role         UserRole        @default(listener)
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  sessions       Session[]
  artists        Artist[]
  playlists      Playlist[]
  likedTracks    LikedTrack[]
  likedAlbums    LikedAlbum[]
  likedPlaylists LikedPlaylist[]
  follows        Follow[]
  playHistory    PlayHistory[]

  @@map("users")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  deviceId         String?   @map("device_id") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.Inet
  userAgent        String?   @map("user_agent")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Artist {
  id            String   @id @default(uuid()) @db.Uuid
  ownerUserId   String?  @map("owner_user_id") @db.Uuid
  name          String   @db.VarChar(255)
  bio           String?
  avatarUrl     String?  @map("avatar_url")
  coverUrl      String?  @map("cover_url")
  verified      Boolean  @default(false)
  followerCount Int      @default(0) @map("follower_count")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  ownerUser       User?                 @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  socials         ArtistSocial[]
  genres          ArtistGenre[]
  albums          Album[]
  tracks          Track[]
  featuredTracks  TrackFeaturedArtist[]
  followers       Follow[]

  @@index([name])
  @@index([ownerUserId])
  @@map("artists")
}

model ArtistSocial {
  id       String @id @default(uuid()) @db.Uuid
  artistId String @map("artist_id") @db.Uuid
  platform String @db.VarChar(80)
  url      String

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, platform])
  @@map("artist_socials")
}

model Genre {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique @db.VarChar(120)
  slug String @unique @db.VarChar(140)

  artists ArtistGenre[]
  albums  AlbumGenre[]
  tracks  TrackGenre[]

  @@map("genres")
}

model ArtistGenre {
  artistId String @map("artist_id") @db.Uuid
  genreId  String @map("genre_id") @db.Uuid

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genre  Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([artistId, genreId])
  @@map("artist_genres")
}

model Album {
  id          String    @id @default(uuid()) @db.Uuid
  artistId    String    @map("artist_id") @db.Uuid
  title       String    @db.VarChar(255)
  type        AlbumType @default(album)
  coverUrl    String?   @map("cover_url")
  releaseDate DateTime? @map("release_date") @db.Date
  trackCount  Int       @default(0) @map("track_count")
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  artist       Artist       @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genres       AlbumGenre[]
  tracks       Track[]
  likedByUsers LikedAlbum[]

  @@index([artistId])
  @@index([isPublished])
  @@map("albums")
}

model AlbumGenre {
  albumId String @map("album_id") @db.Uuid
  genreId String @map("genre_id") @db.Uuid

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([albumId, genreId])
  @@map("album_genres")
}

model Track {
  id              String          @id @default(uuid()) @db.Uuid
  artistId        String          @map("artist_id") @db.Uuid
  albumId         String?         @map("album_id") @db.Uuid
  title           String          @db.VarChar(255)
  durationMs      Int             @map("duration_ms")
  trackNumber     Int?            @map("track_number")
  coverUrl        String?         @map("cover_url")
  audioUrl        String          @map("audio_url")
  storageProvider StorageProvider @default(url) @map("storage_provider")
  storageKey      String?         @map("storage_key")
  mimeType        String          @default("audio/mpeg") @map("mime_type") @db.VarChar(100)
  bitrateKbps     Int?            @map("bitrate_kbps")
  explicit        Boolean         @default(false)
  isPublished     Boolean         @default(false) @map("is_published")
  playCount       BigInt          @default(0) @map("play_count")
  likeCount       BigInt          @default(0) @map("like_count")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  artist          Artist                @relation(fields: [artistId], references: [id], onDelete: Cascade)
  album           Album?                @relation(fields: [albumId], references: [id], onDelete: SetNull)
  genres          TrackGenre[]
  featuredArtists TrackFeaturedArtist[]
  playlistTracks  PlaylistTrack[]
  likedByUsers    LikedTrack[]
  playHistory     PlayHistory[]

  @@index([artistId])
  @@index([albumId])
  @@index([isPublished, playCount])
  @@map("tracks")
}

model TrackGenre {
  trackId String @map("track_id") @db.Uuid
  genreId String @map("genre_id") @db.Uuid

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([trackId, genreId])
  @@map("track_genres")
}

model TrackFeaturedArtist {
  trackId  String @map("track_id") @db.Uuid
  artistId String @map("artist_id") @db.Uuid

  track  Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([trackId, artistId])
  @@map("track_featured_artists")
}

model Playlist {
  id          String             @id @default(uuid()) @db.Uuid
  ownerUserId String             @map("owner_user_id") @db.Uuid
  name        String             @db.VarChar(120)
  description String?
  coverUrl    String?            @map("cover_url")
  visibility  PlaylistVisibility @default(private)
  likeCount   BigInt             @default(0) @map("like_count")
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner        User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  tracks       PlaylistTrack[]
  likedByUsers LikedPlaylist[]

  @@index([ownerUserId])
  @@index([visibility])
  @@map("playlists")
}

model PlaylistTrack {
  id         String   @id @default(uuid()) @db.Uuid
  playlistId String   @map("playlist_id") @db.Uuid
  trackId    String   @map("track_id") @db.Uuid
  position   Int
  addedAt    DateTime @default(now()) @map("added_at") @db.Timestamptz(6)

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, position])
  @@index([trackId])
  @@map("playlist_tracks")
}

model LikedTrack {
  userId    String   @map("user_id") @db.Uuid
  trackId   String   @map("track_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([userId, trackId])
  @@map("liked_tracks")
}

model LikedAlbum {
  userId    String   @map("user_id") @db.Uuid
  albumId   String   @map("album_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@id([userId, albumId])
  @@map("liked_albums")
}

model LikedPlaylist {
  userId     String   @map("user_id") @db.Uuid
  playlistId String   @map("playlist_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([userId, playlistId])
  @@map("liked_playlists")
}

model Follow {
  userId    String   @map("user_id") @db.Uuid
  artistId  String   @map("artist_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([userId, artistId])
  @@map("follows")
}

model PlayHistory {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String?    @map("user_id") @db.Uuid
  trackId   String     @map("track_id") @db.Uuid
  playedMs  Int        @default(0) @map("played_ms")
  completed Boolean    @default(false)
  source    PlaySource @default(direct)
  deviceId  String?    @map("device_id") @db.VarChar(255)
  ipAddress String?    @map("ip_address") @db.Inet
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([trackId, createdAt])
  @@map("play_history")
}
